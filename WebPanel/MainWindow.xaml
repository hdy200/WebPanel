<Window x:Class="WebPanel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="WebPanel"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#CC222222" Cursor="SizeAll">
            <Grid>
                <TextBlock Text="WebPanel" Foreground="#99FFFFFF" FontSize="11"
                           VerticalAlignment="Center" Margin="10,0,0,0" />
                <Button x:Name="MinimizeButton" Content="&#xE949;"
                        FontFamily="Segoe MDL2 Assets" FontSize="14"
                        Width="32" Height="32"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Background="Transparent" Foreground="#99FFFFFF"
                        BorderThickness="0" Cursor="Arrow"
                        Click="MinimizeButton_Click" />
            </Grid>
        </Border>

        <wv2:WebView2 Grid.Row="1" x:Name="WebView" />
    </Grid>
</Window>
